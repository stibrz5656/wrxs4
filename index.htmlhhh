<!DOCTYPE html>
<html lang="ja">
<center>
 <div id="title-text">一時停止標識検知</div>
 <button id="permission-btn" onclick="requestAccess()">加速度センサーを許可</button>
 <button id="start-button" style="display: none;" onclick="init()">開始</button>
 <div class="speed">0.0</div>
 <div class="unit">km/h</div>
 <span id="stop-status" class="highlight">判定中</span>
 <div class="data-box" id="data-area" style="display: none;">
 <span class="label">今の揺れ</span>
 <span id="val-total" class="highlight">0.00</span>
<div id="webcam-container"></div>
<div id="label-container"></div>
</center>
<div id="warning-message">止まれ！</div>
<script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@latest/dist/tf.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@teachablemachine/image@latest/dist/teachablemachine-image.min.js"></script>
<meta name="viewport" content="width=device-width">
<head>
 <style>
  div {color:rgb(0, 0, 0);}
  div {font-size: 40px;}
  button {color:rgb(0, 0, 0);}
  button {font-size: 40px;}
  button {background-color:rgb(0, 208, 250);}
  button {padding: 5px 30px;}
  button {border-radius: 10px;}
  body   {font-family: sans-serif; text-align:right}
  #speed {font-size: 50px; font-weight: bold; color:rgb(0, 0, 0)}
  .unit  {font-size: 30px; }
  #stop-status,#higilight {font-size: 50px; font-weight: bold; color:rgb(0, 0, 0)}
  #webcam-container {
    display: flex;
    justify-content: center; /* 左右中央 */
    align-items: center;     /* 上下中央 */
    min-height: 100vh;      /* 画面全体を高さにする場合 */
}

/* カメラ映像のサイズ調整（任意） */
#webcam-container video {
  width: 100%;   
  max-width: 100%;
  height: auto;
}

#warning-message {
      display: none; /* 最初は隠しておく（超重要） */
      font-size: 80px; /* 文字を巨大に */
      color: white;
      background-color: red;
      font-weight: bold;
      padding: 20px;
      border-radius: 10px;
      white-space: nowrap;
      /* 画面のど真ん中に強制的に配置する魔法のコード */
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 100; /* カメラより手前に出す */
  }
  </style>
</head>


<script type="text/javascript">
    function requestAccess() {
    // 2つ目のボタンの要素を取得
    const nextBtn = document.getElementById("start-button");
    // 表示状態を切り替える（noneからblockにする）
    nextBtn.style.display = 'block';
  }
    // More API functions here:
    // https://github.com/googlecreativelab/teachablemachine-community/tree/master/libraries/image

    // the link to your model provided by Teachable Machine export panel
    const URL = "https://teachablemachine.withgoogle.com/models/_2ZlDZ7MH/";

    let model, webcam, labelContainer, maxPredictions;

    // Load the image model and setup the webcam
    async function init() {
        document.getElementById("title-text").style.display = "inline";     
        document.getElementById("start-button").style.display = "none";
        const modelURL = URL + "model.json";
        const metadataURL = URL + "metadata.json";

        // load the model and metadata
        // Refer to tmImage.loadFromFiles() in the API to support files from a file picker
        // or files from your local hard drive
        // Note: the pose library adds "tmImage" object to your window (window.tmImage)
        model = await tmImage.load(modelURL, metadataURL);
        maxPredictions = model.getTotalClasses();

        // Convenience function to setup a webcam
        const flip = false ; // whether to flip the webcam
        webcam = new tmImage.Webcam(500,500, flip) // width, height, flip
        

        await webcam.setup({ facingMode: "environment" }); // request access to the webcam
        await webcam.play();
        window.requestAnimationFrame(loop);

        // append elements to the DOM
        document.getElementById("webcam-container").appendChild(webcam.canvas);
        labelContainer = document.getElementById("label-container");
        for (let i = 0; i < maxPredictions; i++) { // and class labels
            labelContainer.appendChild(document.createElement("div"));
        }
    }

    async function loop() {
        webcam.update(); // update the webcam frame
        await predict();
        window.requestAnimationFrame(loop);
    }

    // run the webcam image through the image model
    async function predict() {
        const prediction = await model.predict(webcam.canvas);
        
        let isStopDetected = false; // 「止まれ」が見つかったかどうかの目印（フラグ）

        for (let i = 0; i < maxPredictions; i++) {
            const classPrediction =
                prediction[i].className + ": " + prediction[i].probability.toFixed(2);
 

            // ▼▼▼ 追加：止まれの判定 ▼▼▼
            // ※「止まれ」という文字は、Teachable Machineで学習させた時の名前と完全に同じにしてください！
            if (prediction[i].className === "止まれ" && prediction[i].probability > 0.8) {
                isStopDetected = true; // 80%以上なら目印をONにする
                // MP3ファイルを読み込む
const audio = new Audio("stop.mp3");

// 再生する関数
function playMp3() {
    audio.currentTime = 0; // 最初から再生
    audio.play();
}
}  
 }
        // すべての判定が終わった後に、画面の表示を切り替える
        if (isStopDetected === true) {
            // 見つかったら、警告メッセージを表示する（block）
            document.getElementById("warning-message").style.display = "block";
        
        }

        else {
            // 見つからなかったら、隠す（none）
            document.getElementById("warning-message").style.display = "none";
            
        }
    }
  if (navigator.geolocation) {
      // 速度・位置情報の更新を監視
      navigator.geolocation.watchPosition(success, error, {
        enableHighAccuracy: true,
        maximumAge: 0,
        timeout: 5000
      });
    } else {
      alert("このブラウザはGPSに対応していません。");
    }

    function success(position) {
      // 取得できる速度(speed)の単位は「メートル/秒(m/s)」
      let speedMps = position.coords.speed;
      
      if (speedMps !== null) {
        // km/h に変換 (m/s * 3.6)
        let speedKmh = speedMps * 3.6;
        document.getElementById('speed').textContent = speedKmh.toFixed(1);
      } else {
        document.getElementById('speed').textContent = "0.0km/h";
      }
    }

    function error(err) {
      console.warn(`ERROR(${err.code}): ${err.message}`);
    }
 let lastSpokenTime = 0;

    // 直近1秒分の揺れを保存する配列
    let recentValues = [];

    // 実験で記録する値
    let runningValue = null;
    let stoppedValue = null;

    function requestAccess() {
      if (typeof DeviceMotionEvent !== "undefined" &&
          typeof DeviceMotionEvent.requestPermission === "function") {
        DeviceMotionEvent.requestPermission()
          .then(permissionState => {
            if (permissionState === "granted") {
              startSensor();
            } else {
              alert("センサーの利用が拒否されました");
            }
          })
          .catch(console.error);
      } else {
        startSensor();
      }
    }

    function startSensor() {
      window.addEventListener("devicemotion", handleMotion);

      document.getElementById("permission-btn").style.display = "none";
      document.getElementById("start-button").style.display = "block";
      document.getElementById("data-area").style.display = "block";

      speak("測定を開始します、実際の交通ルールに従って走行してください");
    }

function handleMotion(event) {
  let x = event.acceleration.x || 0;
  let y = event.acceleration.y || 0;
  let z = event.acceleration.z || 0;

  // 加速度の大きさ
  let total = Math.sqrt(x * x + y * y + z * z);

  document.getElementById("val-total").innerText = total.toFixed(2);

  // 停止判定（しきい値は必要に応じて調整）
  const threshold = 0.2;

  if (total < threshold) {
    document.getElementById("stop-status").innerText = "停止";
  } else {
    document.getElementById("stop-status").innerText = "走行中";
  }
}
</script>
